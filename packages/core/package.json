{
  "name": "@vortex/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external playwright --external jsdom",
    "dev": "tsup src/index.ts --format esm --dts --watch --external playwright --external jsdom",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "turndown": "^7.2.0",
    "p-queue": "^8.0.0",
    "murmurhash3js-revisited": "^3.0.0",
    "micromatch": "^4.0.8"
  },
  "optionalDependencies": {
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "jsdom": "^25.0.0",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "@types/micromatch": "^4.0.9"
  }
}
