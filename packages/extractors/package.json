{
  "name": "@vortex/extractors",
  "version": "0.1.0",
  "description": "Vortex extractor plugins — YouTube (video/channel/transcript), CSS, JSON-LD schema, and HTML tables.",
  "license": "MIT",
  "author": "Steve Cortes-Pineda",
  "homepage": "https://github.com/Steve-CortesPineda/vortex-crawler#readme",
  "repository": { "type": "git", "url": "git+https://github.com/Steve-CortesPineda/vortex-crawler.git", "directory": "packages/extractors" },
  "bugs": "https://github.com/Steve-CortesPineda/vortex-crawler/issues",
  "keywords": ["web-scraping", "youtube", "extractor", "json-ld", "vortex"],
  "engines": { "node": ">=18" },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@vortex/core": "workspace:*",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
