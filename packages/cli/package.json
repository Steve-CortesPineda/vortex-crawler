{
  "name": "@stevecortesp/vortex-cli",
  "version": "0.1.0",
  "description": "Command-line interface for Vortex — scrape, crawl, map, and search from your terminal.",
  "license": "MIT",
  "author": "Steve Cortes-Pineda",
  "homepage": "https://github.com/Steve-CortesPineda/vortex-crawler#readme",
  "repository": { "type": "git", "url": "git+https://github.com/Steve-CortesPineda/vortex-crawler.git", "directory": "packages/cli" },
  "bugs": "https://github.com/Steve-CortesPineda/vortex-crawler/issues",
  "keywords": ["web-crawler", "web-scraping", "cli", "markdown", "llm"],
  "engines": { "node": ">=18" },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "type": "module",
  "bin": {
    "vortex": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@stevecortesp/vortex-core": "workspace:*",
    "commander": "^13.0.0",
    "chalk": "^5.4.0",
    "ora": "^8.0.0"
  }
}
